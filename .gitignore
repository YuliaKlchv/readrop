# Shared ignore rules for the whole monorepo

# macOS
.DS_Store

# Frontend / Node
node_modules/
dist/

# Environment files
.env
.env.*

# Java / JVM build output
target/
*.class
*.log

# IDEs
.idea/
.vscode/
*.iml

# Security / secrets
*.pem
*.key
*.p12
*.jks
*.keystore

# Local databases
*.db
*.mv.db
*.trace.db

# Local app data
/readrop/data/
/readrop-backend/data/
